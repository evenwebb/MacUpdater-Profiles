{
  "name": "Bruno",
  "slug": "bruno",
  "description": "Open-source offline-first API client \u2014 stores collections as plain text files in your repo, no cloud sync",
  "website": "https://www.usebruno.com",
  "platform": "macOS",
  "architecture": "universal",
  "bundle_id": "com.usebruno.app",
  "category": "developer-tools",
  "license": "free",
  "min_os": "macOS 11.0",
  "auto_updates": true,
  "skip": false,
  "version_check": {
    "method": "github_api",
    "url": "https://api.github.com/repos/usebruno/bruno/releases/latest",
    "extraction": {
      "type": "json_path",
      "path": "tag_name"
    }
  },
  "download": {
    "method": "direct_url",
    "url": "https://www.usebruno.com/downloads",
    "file_type": "dmg"
  },
  "changelog": {
    "method": "github_api",
    "url": "https://api.github.com/repos/usebruno/bruno/releases/latest"
  },
  "release_date": {
    "method": "github_api",
    "field": "published_at"
  },
  "last_updated": "2026-06-22"
}

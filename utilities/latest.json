{
  "name": "Latest",
  "slug": "latest",
  "description": "Free, open-source app for checking if your Mac apps are up to date , supports Sparkle, Homebrew, and App Store apps",
  "website": "https://max.codes/latest",
  "platform": "macOS",
  "architecture": "universal",
  "bundle_id": "com.max-langer.Latest",
  "category": "utilities",
  "license": "free",
  "min_os": "macOS 10.15",
  "auto_updates": true,
  "skip": false,
  "version_check": {
    "method": "github_api",
    "url": "https://api.github.com/repos/mangerlahn/Latest/releases/latest",
    "extraction": {
      "type": "json_path",
      "path": "tag_name"
    }
  },
  "download": {
    "method": "direct_url",
    "url": "https://max.codes/latest/download",
    "file_type": "dmg"
  },
  "changelog": {
    "method": "github_api",
    "url": "https://api.github.com/repos/mangerlahn/Latest/releases/latest"
  },
  "release_date": {
    "method": "github_api",
    "field": "published_at"
  },
  "last_updated": "2026-06-22",
  "icons": {
    "direct_url": "https://raw.githubusercontent.com/evenwebb/macupdater-profiles/main/icons/latest.png"
  }
}
